---
---
<div class="giscus-wrapper">
  <div class="giscus"></div>
</div>

<script is:inline>
  const insertGiscus = () => {
    const existing = document.getElementById('giscus-script');
    if (existing) existing.remove();

    const script = document.createElement('script');
    script.id = 'giscus-script';
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "YOUR_GITHUB_USERNAME/YOUR_REPO_NAME"); // FIXME: User to provide
    script.setAttribute("data-repo-id", "YOUR_REPO_ID"); // FIXME: User to provide
    script.setAttribute("data-category", "General");
    script.setAttribute("data-category-id", "YOUR_CATEGORY_ID"); // FIXME: User to provide
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");
    script.setAttribute("data-theme", "light");
    script.setAttribute("data-lang", "zh-TW");
    script.setAttribute("crossorigin", "anonymous");
    script.async = true;

    document.querySelector('.giscus')?.appendChild(script);
  };

  // Run on first load
  insertGiscus();

  // Run on view transitions if Astro uses it
  document.addEventListener('astro:page-load', insertGiscus);
</script>

<style>
  .giscus-wrapper {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e5e5;
  }
</style>
