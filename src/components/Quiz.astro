---
interface Question {
  question: string;
  options: string[];
  correctIndex: number;
  explanation: string;
}

interface Props {
  questions: Question[];
  quizId?: string; // unique id for localStorage key, defaults to url
}

const { questions, quizId } = Astro.props;
---

<div class="iq-quiz" data-questions={JSON.stringify(questions)} data-quiz-id={quizId ?? ''}>
  <div class="iq-header">
    <span class="iq-icon">🧠</span>
    <div>
      <h3>Knowledge Check</h3>
      <p class="iq-subtitle">選擇答案後點「提交答案」查看結果</p>
    </div>
  </div>
  <div class="iq-body">
    <!-- Rendered by JS -->
  </div>
  <div class="iq-footer">
    <button class="iq-submit-btn" disabled>提交答案</button>
    <button class="iq-retry-btn hidden">🔄 再試一次</button>
    <span class="iq-score-label hidden"></span>
  </div>
</div>

<script>
  const OPTION_LABELS = ['A', 'B', 'C', 'D', 'E', 'F'];

  class IQQuiz {
    private container: HTMLElement;
    private body: HTMLElement;
    private submitBtn: HTMLButtonElement;
    private retryBtn: HTMLButtonElement;
    private scoreLabel: HTMLElement;
    private questions: Array<{
      question: string;
      options: string[];
      correctIndex: number;
      explanation: string;
    }>;
    private quizId: string;
    private selected: (number | null)[];
    private submitted: boolean;

    constructor(container: HTMLElement) {
      this.container = container;
      this.body = container.querySelector('.iq-body')!;
      this.submitBtn = container.querySelector('.iq-submit-btn')!;
      this.retryBtn = container.querySelector('.iq-retry-btn')!;
      this.scoreLabel = container.querySelector('.iq-score-label')!;

      try {
        this.questions = JSON.parse(container.dataset.questions ?? '[]');
      } catch {
        this.questions = [];
      }

      // Unique key for localStorage
      this.quizId = container.dataset.quizId || window.location.pathname;
      this.selected = new Array(this.questions.length).fill(null);
      this.submitted = false;

      this.render();
      this.loadFromStorage();

      this.submitBtn.addEventListener('click', () => this.submit());
      this.retryBtn.addEventListener('click', () => this.retry());
    }

    render() {
      this.body.innerHTML = '';
      this.questions.forEach((q, qi) => {
        const card = document.createElement('div');
        card.className = 'iq-question';
        card.setAttribute('data-qi', String(qi));

        const qTitle = document.createElement('div');
        qTitle.className = 'iq-q-title';
        qTitle.innerHTML = `<span class="iq-q-num">${qi + 1}</span><span>${this.escape(q.question)}</span>`;
        card.appendChild(qTitle);

        const optList = document.createElement('div');
        optList.className = 'iq-opts';

        q.options.forEach((opt, oi) => {
          const btn = document.createElement('button');
          btn.className = 'iq-opt';
          btn.setAttribute('data-oi', String(oi));
          btn.innerHTML = `
            <span class="iq-opt-label">${OPTION_LABELS[oi]}</span>
            <span class="iq-opt-text">${this.escape(opt)}</span>
            <span class="iq-opt-check">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          `;
          btn.addEventListener('click', () => {
            if (!this.submitted) this.selectOption(qi, oi);
          });
          optList.appendChild(btn);
        });

        card.appendChild(optList);

        const expl = document.createElement('div');
        expl.className = 'iq-expl hidden';
        card.appendChild(expl);

        this.body.appendChild(card);
      });
      this.updateSubmitState();
    }

    selectOption(qi: number, oi: number) {
      if (this.submitted) return;
      this.selected[qi] = oi;

      const card = this.body.querySelector(`[data-qi="${qi}"]`)!;
      card.querySelectorAll('.iq-opt').forEach((btn, idx) => {
        btn.classList.toggle('selected', idx === oi);
      });
      this.updateSubmitState();
    }

    updateSubmitState() {
      const allAnswered = this.selected.every(v => v !== null);
      this.submitBtn.disabled = !allAnswered;
    }

    submit() {
      if (this.submitted) return;
      this.submitted = true;
      this.submitBtn.classList.add('hidden');

      let correct = 0;
      this.questions.forEach((q, qi) => {
        const chosen = this.selected[qi] ?? -1;
        const isCorrect = chosen === q.correctIndex;
        if (isCorrect) correct++;

        const card = this.body.querySelector(`[data-qi="${qi}"]`)!;
        card.querySelectorAll('.iq-opt').forEach((btn, oi) => {
          const b = btn as HTMLElement;
          if (oi === q.correctIndex) {
            b.classList.add('iq-correct');
            b.classList.add('iq-bounce');
          } else if (oi === chosen && !isCorrect) {
            b.classList.add('iq-incorrect');
            b.classList.add('iq-shake');
          } else {
            b.classList.add('iq-dimmed');
          }
          (b as HTMLButtonElement).disabled = true;
        });

        const expl = card.querySelector('.iq-expl') as HTMLElement;
        expl.classList.remove('hidden');
        if (isCorrect) {
          expl.classList.add('iq-expl-ok');
          expl.innerHTML = `<span class="expl-icon">🎉</span> <strong>答對了！</strong> ${this.escape(q.explanation)}`;
        } else {
          expl.classList.add('iq-expl-err');
          expl.innerHTML = `<span class="expl-icon">💡</span> <strong>再想想。</strong> ${this.escape(q.explanation)}`;
        }
      });

      // Score display
      const pct = Math.round((correct / this.questions.length) * 100);
      this.scoreLabel.classList.remove('hidden');
      this.scoreLabel.innerHTML = `得分：<strong>${correct} / ${this.questions.length}</strong>（${pct}%）`;
      this.retryBtn.classList.remove('hidden');

      this.saveToStorage(correct);
    }

    retry() {
      this.selected = new Array(this.questions.length).fill(null);
      this.submitted = false;
      this.submitBtn.classList.remove('hidden');
      this.submitBtn.disabled = true;
      this.retryBtn.classList.add('hidden');
      this.scoreLabel.classList.add('hidden');
      this.render();
    }

    saveToStorage(correct: number) {
      try {
        const key = `quiz_${this.quizId}`;
        const data = {
          date: new Date().toISOString(),
          score: correct,
          total: this.questions.length,
          selected: this.selected,
        };
        localStorage.setItem(key, JSON.stringify(data));

        // Append to quiz history list
        const historyKey = 'quiz_history';
        const existing = JSON.parse(localStorage.getItem(historyKey) ?? '[]');
        // Remove old entry for this quiz if exists
        const filtered = existing.filter((e: {quizId: string}) => e.quizId !== this.quizId);
        filtered.push({ quizId: this.quizId, ...data });
        localStorage.setItem(historyKey, JSON.stringify(filtered));
      } catch {
        // Ignore storage errors (e.g. private browsing)
      }
    }

    loadFromStorage() {
      try {
        const key = `quiz_${this.quizId}`;
        const raw = localStorage.getItem(key);
        if (!raw) return;
        const data: { selected: (number|null)[]; score: number; total: number } = JSON.parse(raw);
        if (!Array.isArray(data.selected) || data.selected.length !== this.questions.length) return;
        // Restore selections
        data.selected.forEach((oi, qi) => {
          if (oi !== null) this.selectOption(qi, oi);
        });
      } catch {
        // Ignore
      }
    }

    escape(str: string) {
      return str.replace(/[&<>'"]/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
      }[c] ?? c));
    }
  }

  const init = () => {
    document.querySelectorAll<HTMLElement>('.iq-quiz:not([data-init])').forEach(el => {
      el.setAttribute('data-init', '1');
      new IQQuiz(el);
    });
  };

  document.addEventListener('astro:page-load', init);
  document.addEventListener('DOMContentLoaded', init);
</script>

<style is:global>
  /* ============ CONTAINER ============ */
  .iq-quiz {
    margin: 3rem 0;
    background: var(--bg-surface);
    border: 1px solid var(--border-glass);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.08);
  }

  /* ============ HEADER ============ */
  .iq-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-surface-hover);
  }
  .iq-icon { font-size: 2rem; flex-shrink: 0; }
  .iq-header h3 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .iq-subtitle {
    margin: 0.2rem 0 0;
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  /* ============ BODY ============ */
  .iq-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ============ QUESTION ============ */
  .iq-q-title {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .iq-q-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--gradient-brand);
    color: white;
    font-size: 0.8rem;
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .iq-q-title > span:last-child {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.55;
  }

  /* ============ OPTIONS ============ */
  .iq-opts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.85rem;
    padding-left: 2.8rem; /* indent aligned with question text */
  }

  .iq-opt {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    background: var(--bg-base);
    border: 1.5px solid var(--border-glass);
    border-radius: 10px;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.18s, background 0.18s, transform 0.15s;
    font-family: inherit;
    width: 100%;
    height: 100%;
    min-height: 64px;
  }
  .iq-opt:hover:not(:disabled):not(.iq-correct):not(.iq-incorrect) {
    border-color: var(--accent-violet);
    background: var(--bg-surface-hover);
    transform: translateX(3px);
  }
  .iq-opt.selected {
    border-color: var(--accent-violet);
    background: rgba(139,92,246,0.07);
  }
  .iq-opt.selected .iq-opt-label {
    background: var(--accent-violet);
    color: #fff;
  }
  .iq-opt.selected .iq-opt-check {
    opacity: 1;
    transform: scale(1);
    color: var(--accent-violet);
  }

  /* ABCD badge */
  .iq-opt-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--bg-surface-hover);
    border: 1px solid var(--border-glass);
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s;
  }
  .iq-opt-text {
    flex: 1;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .iq-opt.selected .iq-opt-text { color: var(--text-primary); font-weight: 500; }

  /* Checkmark icon */
  .iq-opt-check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    min-width: 20px;
    min-height: 20px;
    flex-shrink: 0;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.2s var(--ease-out), transform 0.25s var(--ease-out);
    overflow: hidden;
  }
  .iq-opt-check svg {
    display: block;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ============ RESULT STATES ============ */
  .iq-opt.iq-correct {
    border-color: #10b981;
    background: rgba(16,185,129,0.08);
  }
  .iq-opt.iq-correct .iq-opt-label { background: #10b981; color: white; border-color: #10b981; }
  .iq-opt.iq-correct .iq-opt-text { color: #10b981; font-weight: 600; }
  .iq-opt.iq-correct .iq-opt-check { opacity: 1; transform: scale(1); color: #10b981; }

  .iq-opt.iq-incorrect {
    border-color: #f43f5e;
    background: rgba(244,63,94,0.06);
  }
  .iq-opt.iq-incorrect .iq-opt-label { background: #f43f5e; color: white; border-color: #f43f5e; }
  .iq-opt.iq-incorrect .iq-opt-text { color: #f43f5e; text-decoration: line-through; }
  .iq-opt.iq-incorrect .iq-opt-check { opacity: 0 !important; }

  .iq-opt.iq-dimmed {
    opacity: 0.45;
  }

  /* Animations */
  @keyframes iq-bounce {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.04); }
    60%  { transform: scale(0.97); }
    100% { transform: scale(1); }
  }
  @keyframes iq-shake {
    0%,100% { transform: translateX(0); }
    20%     { transform: translateX(-6px); }
    40%     { transform: translateX(6px); }
    60%     { transform: translateX(-4px); }
    80%     { transform: translateX(4px); }
  }
  .iq-bounce { animation: iq-bounce 0.5s var(--ease-out) forwards; }
  .iq-shake  { animation: iq-shake  0.45s ease forwards; }

  /* ============ EXPLANATION ============ */
  .iq-expl {
    margin-top: 1rem;
    margin-left: 2.8rem;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    font-size: 0.92rem;
    line-height: 1.65;
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    animation: expl-in 0.3s var(--ease-out);
  }
  @keyframes expl-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .iq-expl.hidden { display: none; }
  .expl-icon { font-size: 1.1rem; flex-shrink: 0; }
  .iq-expl-ok  { background: rgba(16,185,129,0.1);  color: #059669; border-left: 4px solid #10b981; }
  .iq-expl-err { background: rgba(244,63,94,0.08);  color: #e11d48; border-left: 4px solid #f43f5e; }

  /* ============ FOOTER ============ */
  .iq-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 2rem;
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-surface-hover);
    flex-wrap: wrap;
  }
  .iq-submit-btn {
    padding: 0.65rem 1.75rem;
    border-radius: 10px;
    border: none;
    background: var(--gradient-brand);
    color: white;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: inherit;
  }
  .iq-submit-btn:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .iq-submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .iq-retry-btn {
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    border: 1px solid var(--border-glass);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }
  .iq-retry-btn:hover { background: var(--bg-surface-hover); color: var(--text-primary); }
  .iq-score-label {
    margin-left: auto;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .iq-score-label strong { color: var(--text-primary); }
  .hidden { display: none !important; }
</style>
