---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Andy's Pro — AI & Engineering Blog", lang = 'en' } = Astro.props;
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;

const isEn = lang === 'en';
const isTw = lang === 'zh-tw';
const isCn = lang === 'zh-cn';

const linkPrefix = isEn ? '' : `/${lang}`;

const t = {
  blog: isEn ? 'Blog' : isCn ? '博客' : '文章',
  courses: isEn ? 'Courses' : isCn ? '课程' : '課程',
  members: isEn ? 'Members' : isCn ? '会员' : '會員',
  logout: isEn ? 'Logout' : isCn ? '登出' : '登出',
  login: isEn ? 'Login' : isCn ? '登入' : '登入',
  signup: isEn ? 'Sign Up' : isCn ? '加入' : '加入',
};

function getLocalizedUrl(targetLang: string) {
  let basePath = currentPath;
  if (basePath.startsWith('/zh-tw')) basePath = basePath.replace('/zh-tw', '');
  else if (basePath.startsWith('/zh-cn')) basePath = basePath.replace('/zh-cn', '');
  
  if (targetLang === 'en') return basePath || '/';
  if (basePath === '' || basePath === '/') return `/${targetLang}`;
  return `/${targetLang}${basePath}`;
}
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap" rel="stylesheet" />
    <!-- llms.txt: expose raw markdown content for AI agents -->
    <link rel="alternate" type="text/markdown" href="https://github.com/andystv/andystv-web/tree/main/src/content" title="Raw Markdown Source" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body>
    <!-- Ambient background blobs -->
    <div class="bg-ambient" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>

    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="site-logo">
          <span class="logo-icon">⬡</span>
          <span class="logo-text">Andy's Pro</span>
        </a>

        <ul class="nav-menu">
          <li><a href={`${linkPrefix}/blog`} class={`nav-link ${currentPath.includes('/blog') ? 'active' : ''}`}>{t.blog}</a></li>
          <li><a href={`${linkPrefix}/courses`} class={`nav-link ${currentPath.includes('/courses') ? 'active' : ''}`}>{t.courses}</a></li>
          {user && (
            <>
              <li><a href="/members/dashboard" class="nav-link">{t.members}</a></li>
              <li>
                <form action="/auth/logout" method="POST" style="display: inline;">
                  <button type="submit" class="nav-btn-ghost">{t.logout}</button>
                </form>
              </li>
            </>
          )}
          {!user && (
            <>
              <li><a href="/auth/login" class="nav-btn-ghost">{t.login}</a></li>
              <li><a href="/auth/signup" class="nav-btn-primary">{t.signup}</a></li>
            </>
          )}

          <li class="lang-switcher">
            <a href={getLocalizedUrl('en')} class={`lang-btn ${isEn ? 'active' : ''}`}>EN</a>
            <span class="lang-sep">|</span>
            <a href={getLocalizedUrl('zh-tw')} class={`lang-btn ${isTw ? 'active' : ''}`}>繁</a>
            <span class="lang-sep">|</span>
            <a href={getLocalizedUrl('zh-cn')} class={`lang-btn ${isCn ? 'active' : ''}`}>简</a>
          </li>

          <li>
            <button id="theme-toggle" aria-label="Toggle theme" class="theme-toggle">
              <span class="sun-icon">☀️</span>
              <span class="moon-icon">🌙</span>
            </button>
          </li>
        </ul>

        <button class="hamburger" id="hamburger" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </nav>

      <!-- Mobile drawer -->
      <div class="mobile-drawer" id="mobile-drawer">
        <a href={`${linkPrefix}/blog`} class="mobile-link">{t.blog}</a>
        <a href={`${linkPrefix}/courses`} class="mobile-link">{t.courses}</a>
        <div class="mobile-lang-switcher">
          <a href={getLocalizedUrl('en')} class={isEn ? 'active' : ''}>EN</a> / 
          <a href={getLocalizedUrl('zh-tw')} class={isTw ? 'active' : ''}>繁</a> / 
          <a href={getLocalizedUrl('zh-cn')} class={isCn ? 'active' : ''}>简</a>
        </div>
        {!user && <a href="/auth/login" class="mobile-link">{t.login} / {t.signup}</a>}
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="logo-icon">⬡</span>
          <span class="footer-name">Andy's Pro</span>
          <p class="footer-tagline">成為成功的工程師，分享最前線技術</p>
        </div>

        <div class="footer-links-grid">
          <div>
            <h5>內容</h5>
            <ul>
              <li><a href="/blog">中文文章</a></li>
              <li><a href="/en">英文文章</a></li>
              <li><a href="/courses">線上課程</a></li>
            </ul>
          </div>
          <div>
            <h5>社群</h5>
            <ul>
              <li><a href="https://youtube.com/@AndysTV" target="_blank" rel="noopener">YouTube</a></li>
              <li><a href="https://github.com/andystv" target="_blank" rel="noopener">GitHub</a></li>
            </ul>
          </div>
          <div>
            <h5>訂閱</h5>
            <ul>
              <li><a href="https://buttondown.email/andystv" target="_blank" rel="noopener">電子報</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Andy's Pro. All rights reserved.</p>
        <p class="footer-ai-note">📖 AI-Friendly: raw markdown available at <a href="https://github.com/andystv/andystv-web/tree/main/src/content" target="_blank" rel="noopener">GitHub</a></p>
      </div>
    </footer>

    <script>
      const hamburger = document.getElementById('hamburger');
      const drawer = document.getElementById('mobile-drawer');
      
      // Theme Toggle Logic
      const themeToggle = document.getElementById('theme-toggle');
      const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle('dark');
        
        const isDark = element.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        element.setAttribute('data-theme', isDark ? 'dark' : 'light');
      };
      themeToggle?.addEventListener('click', handleToggleClick);

      hamburger?.addEventListener('click', () => {
        drawer?.classList.toggle('open');
        hamburger.classList.toggle('open');
      });
      // Close drawer on link click
      drawer?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          drawer.classList.remove('open');
          hamburger?.classList.remove('open');
        });
      });

      // --- MAC-STYLE CODE BLOCKS INIT ---
      const initMacCodeBlocks = () => {
        const preElements = document.querySelectorAll('.prose pre:not(.mac-processed)');
        preElements.forEach(pre => {
          pre.classList.add('mac-processed');
          
          // Try to get language
          let lang = (pre.getAttribute('data-language') || pre.className.match(/language-(\w+)/)?.[1] || 'code').toUpperCase();

          // Create wrapper
          const wrapper = document.createElement('div');
          wrapper.className = 'mac-code-wrapper';
          pre.parentNode?.insertBefore(wrapper, pre);
          
          // Create Header
          const header = document.createElement('div');
          header.className = 'mac-code-header';
          header.innerHTML = `
            <div class="mac-lights">
              <span class="mac-light red"></span>
              <span class="mac-light yellow"></span>
              <span class="mac-light green"></span>
            </div>
            <div class="mac-lang">${lang}</div>
            <button class="mac-copy" aria-label="Copy code">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            </button>
          `;

          // Handle Copy
          const copyBtn = header.querySelector('.mac-copy') as HTMLButtonElement;
          copyBtn.addEventListener('click', async () => {
            const codeEl = pre.querySelector('code');
            if (codeEl) {
              await navigator.clipboard.writeText(codeEl.innerText);
              copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" class="css-i6dzq1"><polyline points="20 6 9 17 4 12"></polyline></svg>';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                copyBtn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
                copyBtn.classList.remove('copied');
              }, 2000);
            }
          });

          wrapper.appendChild(header);
          wrapper.appendChild(pre);
        });
      };

      document.addEventListener('astro:page-load', initMacCodeBlocks);
      document.addEventListener('DOMContentLoaded', initMacCodeBlocks);

    </script>
  </body>
</html>

<style is:global>
  /* ============================================
     CSS RESET & DESIGN TOKENS
  ============================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Base typography, layout, animations */
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'Fira Code', 'Cascadia Code', monospace;
    --nav-height: 64px;
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);

    /* Light Theme (Default) */
    --bg-base: #fafafa;
    --bg-surface: #ffffff;
    --bg-surface-hover: #f4f4f5;
    --bg-glass: rgba(255, 255, 255, 0.85);
    --bg-glass-hover: rgba(255, 255, 255, 0.95);
    --border-subtle: rgba(0, 0, 0, 0.08);
    --border-glass: rgba(0, 0, 0, 0.12);
    --text-primary: #18181b;
    --text-secondary: #52525b;
    --text-tertiary: #a1a1aa;
    
    /* Premium accents */
    --accent-violet: #8b5cf6;
    --accent-cyan: #06b6d4;
    --accent-amber: #f59e0b;
    /* Legacy aliases to prevent sudden breakage */
    --accent-green: var(--accent-cyan);
    --accent-red: var(--accent-violet);
    --accent-yellow: var(--accent-amber);
    
    --gradient-brand: linear-gradient(135deg, var(--accent-violet), var(--accent-cyan));
    --gradient-hero: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.1));
    --border-active: rgba(139, 92, 246, 0.6);
    --glass-blur: blur(12px) saturate(150%);
    --glass-bg: rgba(255, 255, 255, 0.6);
    --glass-border: rgba(0, 0, 0, 0.1);
    --nav-bg: rgba(250, 250, 250, 0.85);
  }

  :root[data-theme='dark'] {
    --bg-base: #09090b;
    --bg-surface: rgba(255, 255, 255, 0.03);
    --bg-surface-hover: rgba(255, 255, 255, 0.05);
    --bg-glass: rgba(9, 9, 11, 0.7);
    --bg-glass-hover: rgba(24, 24, 27, 0.85);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --border-glass: rgba(255, 255, 255, 0.12);
    --text-primary: rgba(255, 255, 255, 0.95);
    --text-secondary: rgba(255, 255, 255, 0.65);
    --text-tertiary: rgba(255, 255, 255, 0.4);

    --glass-bg: rgba(24, 24, 27, 0.6);
    --glass-border: rgba(255, 255, 255, 0.1);
    --gradient-hero: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.1));
    --nav-bg: rgba(9, 9, 11, 0.8);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg-base);
    color: var(--text-primary);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow-x: hidden;
  }

  main {
    flex: 1;
  }

  /* ============================================
     ENGINEERING GRID BACKGROUND
  ============================================ */
  .bg-ambient {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-color: var(--bg-base);
    background-image: 
      linear-gradient(var(--border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
    background-size: 30px 30px;
    background-position: center top;
  }

  /* Core vignette effect */
  .bg-ambient::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 30%, transparent 20%, var(--bg-base) 80%);
  }

  /* ============================================
     LIQUID GLASS HEADER / NAV
  ============================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background: var(--nav-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    transition: opacity 0.2s;
  }

  .site-logo:hover { opacity: 0.8; }

  .logo-icon {
    font-size: 1.4rem;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .logo-text {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin-left: auto;
  }

  .nav-link {
    display: block;
    padding: 0.45rem 0.85rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s var(--ease-out);
    position: relative;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-surface-hover);
  }

  .nav-link.active {
    color: var(--accent-violet);
    background: rgba(139, 92, 246, 0.12);
  }

  .nav-btn-ghost {
    padding: 0.45rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border-glass);
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: all 0.2s var(--ease-out);
  }

  .nav-btn-ghost:hover {
    color: var(--text-primary);
    background: var(--bg-surface-hover);
    border-color: var(--border-glass);
  }

  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.5rem;
    border-left: 1px solid var(--border-subtle);
    margin-left: 0.5rem;
  }
  .lang-btn {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .lang-btn:hover { color: var(--text-primary); }
  .lang-btn.active { color: var(--accent-violet); }
  .lang-sep { font-size: 0.75rem; color: var(--border-subtle); }

  .mobile-lang-switcher {
    padding: 1rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-glass);
  }
  .mobile-lang-switcher a { color: var(--text-tertiary); text-decoration: none; padding: 0 0.2rem; }
  .mobile-lang-switcher a.active { color: var(--accent-violet); }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border-glass);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1.1rem;
    position: relative;
    overflow: hidden;
  }
  .theme-toggle:hover {
    background: var(--bg-surface-hover);
    color: var(--text-primary);
  }
  .theme-toggle .sun-icon, .theme-toggle .moon-icon {
    position: absolute;
    transition: transform 0.3s var(--ease-out), opacity 0.3s var(--ease-out);
  }
  /* Default (Light Mode): Sun is hidden (rotated out), Moon is visible */
  :root[data-theme='light'] .sun-icon,
  :root:not([data-theme='dark']) .sun-icon {
    transform: translateY(20px) rotate(45deg);
    opacity: 0;
  }
  :root[data-theme='light'] .moon-icon,
  :root:not([data-theme='dark']) .moon-icon {
    transform: translateY(0) rotate(0);
    opacity: 1;
  }
  /* Dark Mode: Sun is visible, Moon is hidden */
  :root[data-theme='dark'] .sun-icon {
    transform: translateY(0) rotate(0);
    opacity: 1;
  }
  :root[data-theme='dark'] .moon-icon {
    transform: translateY(-20px) rotate(-45deg);
    opacity: 0;
  }

  .nav-btn-primary {
    padding: 0.45rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: white;
    background: var(--gradient-brand);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.3);
    transition: all 0.2s var(--ease-out);
  }

  .nav-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
  }

  /* ----------------------------------------
     Hamburger (mobile)
  ---------------------------------------- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: var(--bg-surface);
    border: 1px solid var(--border-glass);
    border-radius: 8px;
    cursor: pointer;
    padding: 7px;
  }

  .hamburger span {
    display: block;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.3s;
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-drawer {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    background: rgba(9, 9, 17, 0.95);
    backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--border-glass);
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transform: translateY(-120%);
    opacity: 0;
    transition: all 0.3s var(--ease-out);
    z-index: 99;
  }

  .mobile-drawer.open {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s;
  }

  .mobile-link:hover {
    color: var(--text-primary);
    background: var(--bg-surface-hover);
  }

  /* ============================================
     FOOTER
  ============================================ */
  .site-footer {
    border-top: 1px solid var(--border-subtle);
    background: rgba(255,255,255,0.02);
    padding: 3rem 1.5rem 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    gap: 4rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 180px;
  }

  .footer-brand .logo-icon {
    font-size: 1.5rem;
  }

  .footer-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    line-height: 1.6;
    max-width: 220px;
  }

  .footer-links-grid {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
  }

