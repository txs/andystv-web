---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.id.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Andy's Pro — AI & Engineering Blog" lang="en">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        2026 · Tech Blog &amp; Courses
      </div>
      <h1 class="hero-title">
        Become a <span class="gradient-text"> Successful Engineer</span>,<br/>
        Explore the AI Frontier
      </h1>
      <p class="hero-desc">
        Hi, I am Andy! A CMLab researcher & fullstack engineer. I share the latest tech insights, practical courses, and industry perspectives here. Free tutorials to get started, comprehensive courses to master.
      </p>
      <div class="hero-actions">
        <a href="/courses" class="btn-primary">🚀 Explore Courses</a>
        <a href="/blog" class="btn-ghost">📖 Read Articles</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">18+</span>
          <span class="stat-label">Course Chapters</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">Free</span>
          <span class="stat-label">Core Tutorials</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">2026</span>
          <span class="stat-label">Modern Tech</span>
        </div>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="code-window">
        <div class="code-dots">
          <span></span><span></span><span></span>
        </div>
        <div class="code-content">
          <div class="code-line"><span class="kw">const</span> <span class="var">engineer</span> = {"{"}</div>
          <div class="code-line indent"><span class="str">name</span>: <span class="val">"Andy"</span>,</div>
          <div class="code-line indent"><span class="str">skills</span>: [<span class="val">"AI"</span>, <span class="val">"Fullstack"</span>],</div>
          <div class="code-line indent"><span class="str">mission</span>: <span class="val">"Share &amp; Grow"</span>,</div>
          <div class="code-line indent"><span class="str">year</span>: <span class="val">2026</span>,</div>
          <div class="code-line">{"}"};</div>
          <div class="code-line">&nbsp;</div>
          <div class="code-line"><span class="kw">async function</span> <span class="fn">success</span>() {"{"}</div>
          <div class="code-line indent"><span class="kw">await</span> learn(<span class="val">"consistently"</span>);</div>
          <div class="code-line indent"><span class="kw">await</span> build(<span class="val">"projects"</span>);</div>
          <div class="code-line indent"><span class="kw">return</span> <span class="val">"🏆"</span>;</div>
          <div class="code-line">{"}"}</div>
          <div class="cursor-blink">|</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FRONTEND SKILLS ===== -->
  <section class="skills-section">
    <div class="section-container">
      <div class="section-header">
        <span class="section-label">Tech Stack</span>
        <h2>Modern Web & AI</h2>
      </div>
      <div class="skills-grid">
        <div class="tech-card skill-card">
          <div class="skill-icon">⚛️</div>
          <h3>React Ecosystem</h3>
          <p>Building highly interactive UIs with React, Next.js, and modern state management tools.</p>
        </div>
        <div class="tech-card skill-card">
          <div class="skill-icon">🚀</div>
          <h3>Astro Framework</h3>
          <p>Delivering lightning-fast, content-driven websites with Islands Architecture (like this blog!).</p>
        </div>
        <div class="tech-card skill-card">
          <div class="skill-icon">⚡</div>
          <h3>Fullstack Node / Bun</h3>
          <p>Robust backend API development, database integration, and high-performance JS over the wire.</p>
        </div>
        <div class="tech-card skill-card">
          <div class="skill-icon">🧠</div>
          <h3>AI Integration</h3>
          <p>Connecting LLMs, building autonomous agents (OpenClaw), and integrating RAG systems.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    padding: 0 5%;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    flex: 1;
    max-width: 600px;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-violet);
    margin-bottom: 2rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-cyan);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--accent-cyan);
    animation: pulse 2s infinite;
  }

  .hero-title {
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .gradient-text {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .btn-primary, .btn-ghost {
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--gradient-brand);
    color: white;
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.4);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.6);
  }

  .btn-ghost {
    background: var(--bg-glass);
    color: var(--text-primary);
    border: 1px solid var(--border-glass);
  }
  .btn-ghost:hover {
    background: var(--bg-glass-hover);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border-subtle);
  }

  /* Visual Code Window */
  .hero-visual {
    flex: 1;
    max-width: 600px;
    perspective: 1000px;
  }

  .code-window {
    background: #09090b;
    border: 1px solid #27272a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: rotateY(-5deg) rotateX(5deg);
    transition: transform 0.3s ease;
  }
  .code-window:hover {
    transform: rotateY(0) rotateX(0);
  }

  .code-dots {
    display: flex;
    gap: 6px;
    padding: 12px 16px;
    background: #18181b;
    border-bottom: 1px solid #27272a;
  }
  .code-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .code-dots span:nth-child(1) { background: #ef4444; }
  .code-dots span:nth-child(2) { background: #eab308; }
  .code-dots span:nth-child(3) { background: #22c55e; }

  .code-content {
    padding: 1.5rem;
    font-family: 'Fira Code', monospace;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #e4e4e7;
  }

  .code-line { display: flex; }
  .indent { padding-left: 1.5rem; }
  .kw { color: #c678dd; } /* keyword */
  .var { color: #e5c07b; } /* variable */
  .str { color: #98c379; } /* string key */
  .val { color: #61afef; } /* string value */
  .fn { color: #61afef; } /* function */

  .cursor-blink {
    animation: blink 1s step-end infinite;
    color: var(--accent-cyan);
    font-weight: bold;
  }

  /* Skills Section */
  .skills-section {
    padding: 6rem 0;
    position: relative;
    z-index: 2;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .skill-card {
    padding: 2rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .skill-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .skill-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .skill-card p {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  @keyframes pulse {
    0% { opacity: 1; box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.4); }
    70% { opacity: 0.5; box-shadow: 0 0 0 6px rgba(6, 182, 212, 0); }
    100% { opacity: 1; box-shadow: 0 0 0 0 rgba(6, 182, 212, 0); }
  }
  @keyframes blink { 50% { opacity: 0; } }

  @media (max-width: 1024px) {
    .hero {
      flex-direction: column;
      text-align: center;
      padding-top: 4rem;
    }
    .hero-stats {
      justify-content: center;
    }
    .hero-actions {
      justify-content: center;
    }
  }
</style>